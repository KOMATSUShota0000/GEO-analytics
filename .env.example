# ===========================================================================
# GEO-analytics 環境変数サンプル（見本・公開対象）
# ⚠️ このファイルには絶対に実値を書かないこと。実値は `.env`（gitignore済み）へ。
# 使い方: このファイルを `.env` にコピーし、各値を埋める。
# ===========================================================================

# --- データベース（共通） ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=geo_analytics

# --- Flyway（マイグレーション実行ユーザー = postgres 等の権限保持者） ---
FLYWAY_USER=postgres
FLYWAY_PASSWORD=

# --- アプリ用DBロール（RLS適用ワーカー） ---
# パスワードは強いランダム値を必須で設定する（未設定だと起動時にDB接続で失敗）。
# 生成例(bash): openssl rand -base64 24
API_WORKER_USER=api_worker
API_WORKER_PASSWORD=
BATCH_WORKER_USER=batch_worker
BATCH_WORKER_PASSWORD=

# --- 本番(prod)プロファイル用 ---
DB_USER=postgres
DB_PASSWORD=

# --- 認証 / JWT ---
# 256bit 以上のランダム値を必須で設定する（未設定だと起動時にトークン生成で失敗）。
# 生成例(PowerShell): $b=New-Object byte[] 64; [System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($b); ([BitConverter]::ToString($b) -replace '-','').ToLower()
# 生成例(bash):       openssl rand -hex 64
JWT_SECRET=

# --- AI / 外部API ---
# Google Gemini APIキー。Google Cloud で発行。
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash
# SerpAPI（競合エビデンス取得）
SERPAPI_API_KEY=
# Google Places API
GOOGLE_PLACES_API_KEY=

# --- Redis（crawler キャッシュ。redis-enabled=false の間は不要） ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- その他 ---
APP_PDF_TEMP_DIR=./data/pdf-temp
APP_NOTIFICATIONS_MAIL_FROM=noreply@example.com
