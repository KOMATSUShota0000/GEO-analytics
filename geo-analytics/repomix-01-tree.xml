                0));
        when(hybridCompetitorPipelineService.executePipeline(
                        any(UUID.class),
                        any(UUID.class),
                        anyString(),
                        nullable(CompetitorExtractionMode.class)))
                .thenReturn(
                        List.of(
                                new SelectedCompetitor(
                                        "SyntheticA",
                                        "https://synthetic-a.example",
                                        null,
                                        null,
                                        "test",
                                        true),
                                new SelectedCompetitor(
