        }
        if (v == 0) {
            return emitSingle(k, out, o, max);
        }
        switch (k) {
            case '\u30AD':
                return put3(out, o, max, 'k', 'y', v);
            case '\u30AE':
                return put3(out, o, max, 'g', 'y', v);
