function computeReadinessYMin(values: number[]): number {
  const finite = values.filter((n) => Number.isFinite(n));
  if (finite.length === 0) {
    return 0.0;
  }
  const min = Math.min(...finite);
  return Math.max(0.0, min - 5.0);
}

