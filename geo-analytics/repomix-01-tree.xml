    private static List<String> normalizeThreeUrls(List<String> urls) {
        List<String> out = new ArrayList<>();
        if (urls != null) {
            for (String url : urls) {
                out.add(url != null ? url : "");
                if (out.size() == 3) {
                    return new ArrayList<>(out);
                }
            }
        }
        while (out.size() < 3) {
            out.add("");
        }
        return new ArrayList<>(out);
    }
