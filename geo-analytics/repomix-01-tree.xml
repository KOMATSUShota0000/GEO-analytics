                }}
              />
              <Box
                onClick={() => {
                  if (!submitting) {
                    fileInputRef.current?.click();
                  }
                }}
                onDragOver={(ev) => {
                  ev.preventDefault();
                  ev.stopPropagation();
                }}
                onDrop={(ev) => {
                  ev.preventDefault();
                  ev.stopPropagation();
