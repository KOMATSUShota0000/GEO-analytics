                id,
                extractContextRequest.url(),
                extractContextRequest.industryHint(),
                extractContextRequest.sessionId());
        return projectContextService
                .getContext(id)
                .map(ResponseEntity::ok)
                .orElseThrow(() -> new EntityNotFoundException("Project not found: " + id));
