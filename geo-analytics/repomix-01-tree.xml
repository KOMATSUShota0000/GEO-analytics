              spacing={2}
              alignItems="flex-start"
            >
              <Box sx={{ flex: 1, minWidth: 0, width: "100%" }}>
                <OnboardingNarrationMonitor entries={narrationLog} />
              </Box>
              <Box sx={{ flex: 1, minWidth: 0, width: "100%" }}>
                <OnboardingMathVisualizer
