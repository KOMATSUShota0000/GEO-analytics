          <Alert severity="error" sx={{ mb: 2 }} onClose={dismissStreamAlerts}>
            {streamChannelError}
          </Alert>
        )}
        {settlementNotice !== null && settlementNotice.trim().length > 0 && (
          <Alert severity="warning" sx={{ mb: 2 }} onClose={dismissStreamAlerts}>
