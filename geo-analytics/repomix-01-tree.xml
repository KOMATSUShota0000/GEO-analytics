            case INNOVATOR -> INNOVATOR_BASE;
            case DIRECTOR -> DIRECTOR_BASE;
        };
    }

    /**
     * 業種ヒントに応じた追補指示。{@code industryType} が null の場合は {@link IndustryType#OTHER} 相当の扱いを呼び出し側で行うか、ここで OTHER として扱う。
