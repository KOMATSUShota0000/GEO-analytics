            setData((prev) => {
              if (prev === null || !Array.isArray(prev.remediationTasks)) {
                return prev;
              }
              const nextTasks = prev.remediationTasks.map((t) =>
                t.id === updated.id ? updated : t,
              );
              return { ...prev, remediationTasks: nextTasks };
            });
