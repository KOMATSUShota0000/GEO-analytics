                </Stack>
                {queries.length > 0 && (
                  <Stack direction="row" flexWrap="wrap" gap={1} sx={{ mt: 2 }}>
                    {queries.map((q) => (
                      <Chip key={q} label={q} onDelete={() => removeQuery(q)} />
                    ))}
