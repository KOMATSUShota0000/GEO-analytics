                .isEqualTo("\u30ad\u30e4\u30ce\u30f3");
    }

    @Test
    void shouldStripEnglishCorpSuffix() {
        assertThat(JapaneseTextNormalizer.normalizeBrandText("Sony Corp.")).isEqualTo("Sony ");
