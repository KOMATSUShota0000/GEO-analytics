    if (item === null || typeof item !== "object") {
      return null;
    }
    const o = item as Record<string, unknown>;
    const nm = o.name;
    const sh = o.share;
    if (typeof nm !== "string" || typeof sh !== "number" || Number.isNaN(sh)) {
