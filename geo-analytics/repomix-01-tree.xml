                            {row.recommendedActions != null && row.recommendedActions.length > 0 ? (
                              <ul className="list-disc space-y-0.5 pl-4">
                                {row.recommendedActions.map((action, ai) => (
                                  <li key={`${row.resultId}-${ai}`}>{action}</li>
