    public void cancelBatchJob(String geminiBatchJobName) {
        String cancelUrl = GEMINI_API_BASE_URL + "/v1beta/" + geminiBatchJobName + ":cancel?key=" + geminiApiKey;
        try {
            restClient.post()
                .uri(URI.create(cancelUrl))
