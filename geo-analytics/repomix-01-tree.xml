          <p className="mt-2 text-sm">{jobNotifyError}</p>
        </div>
      )}
      <div className="pdf-no-print mb-6 flex flex-wrap items-center gap-2">
        <label htmlFor="jobId" className="text-sm font-medium text-slate-700">
          ジョブID
