    }

    private static char smallVowel(char small) {
        if (small == '\u30E3' || small == '\u30A1') {
            return 'a';
        }
        if (small == '\u30E5' || small == '\u30A5') {
            return 'u';
        }
        if (small == '\u30E7' || small == '\u30A9') {
            return 'o';
        }
        if (small == '\u30A3') {
            return 'i';
        }
        if (small == '\u30A7') {
            return 'e';
        }
        return 0;
    }

    private static int put(char[] out, int o, int max, char a) {
        if (o < max) {
            out[o++] = a;
