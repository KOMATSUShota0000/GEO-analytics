        double pB = VisibilityStageMapper.define(3, 4).progressRate();
        double pC = VisibilityStageMapper.define(3, 5).progressRate();
        assertThat(pA).isEqualTo(1.0);
        assertThat(pB).isGreaterThan(pC);
        assertThat(pC).isEqualTo(0.0);
    }
