    @BeforeEach
    void setUp() {
        filter = new JwtAuthenticationFilter(tokenService, userSessionRepository, userSessionsCache);
    }

    @AfterEach
    void tearDown() {
        TenantContextHolder.clear();
        SecurityContextHolder.clearContext();
    }

