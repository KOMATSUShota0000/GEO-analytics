        assertThat(gatekeeperCaptor.getValue()).isEqualTo(gatekeeperResult);
        assertThat(entropyCaptor.getValue()).isEqualTo(entropyMetrics);
        assertThat(semanticCaptor.getValue()).isEqualTo(semanticOutcome);
