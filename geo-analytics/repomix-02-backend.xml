    private UUID gapBatchIdempotencyKey;
    @Column(name = "create_idempotency_key")
    private UUID createIdempotencyKey;
    @Column(name = "gap_analysis_gemini_job_name", length = 512)
    private String gapAnalysisGeminiJobName;
