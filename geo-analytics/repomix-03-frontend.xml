  }
  const mrRaw = r.mentionRank;
  const mentionRank =
    mrRaw === null || mrRaw === undefined
      ? null
      : typeof mrRaw === "number" && !Number.isNaN(mrRaw)
        ? mrRaw
        : null;
  const osRaw = r.overallScore;
  const overallScore =
    osRaw === null || osRaw === undefined
      ? null
      : typeof osRaw === "number" && !Number.isNaN(osRaw)
