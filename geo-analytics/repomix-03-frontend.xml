  const tier = getSomTierInfo(somScore);
  const showUpsell = !isProPlan && somScore >= 69.5;
  return (
    <div className="pdf-avoid-break overflow-hidden rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
