        if (ch >= '\uFF66' && ch <= '\uFF70') {
            switch (ch) {
                case '\uFF66':
                    return '\u30F2';
                case '\uFF67':
                    return '\u30A1';
                case '\uFF68':
                    return '\u30A3';
                case '\uFF69':
                    return '\u30A5';
                case '\uFF6A':
                    return '\u30A7';
                case '\uFF6B':
                    return '\u30A9';
                case '\uFF6C':
                    return '\u30E3';
                case '\uFF6D':
                    return '\u30E5';
                case '\uFF6E':
                    return '\u30E7';
                case '\uFF6F':
                    return '\u30C3';
                case '\uFF70':
                    return '\u30FC';
                default:
                    return ch;
